# --- Jira (Cloud) ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token          # id.atlassian.com/manage/api-tokens
# Optional: the custom field id for the "Flagged / Impediment" field, if you use
# it to mark blocked work. Find it in Jira admin -> Custom fields. Leave unset to
# detect blocked items only via a "blocked" label.
# JIRA_FLAGGED_FIELD_ID=customfield_10021

# --- LLM via your LiteLLM proxy (OpenAI-compatible, fronting Bedrock) ---
LITELLM_BASE_URL=https://your-litellm-host/v1
LITELLM_API_KEY=sk-...
LITELLM_MODEL=bedrock-claude                 # whatever model name your proxy exposes

# --- Slack (Incoming Webhook to a private channel, to start) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
